# ─────────────────────────────────────────────────────────────────────────────
# Шаблон окружения. Скопируйте в .env и подставьте свои значения:
#   cp .env.example .env
# Файл .env в репозиторий НЕ коммитится (см. .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Pexels API для фоновых фото в карточках (приоритет, работает с VPS).
# Получить бесплатно: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key

# Pixabay API (резервный провайдер, работает локально, блокирует VPS).
# Получить бесплатно: https://pixabay.com/api/
PIXABAY_API_KEY=your_pixabay_api_key

# Production: подключение к вашей PostgreSQL с news_list.
PG_CONNINFO="dbname=serp_robot user=USER password=PASSWORD host=DB_HOST port=5432"

# Если news_list лежит не в public, укажите схему вручную.
# NEWS_SCHEMA=public
NEWS_TABLE=news_list

# Схема, где backend/worker создают постоянные таблицы событий.
# В этой схеме появятся: events, event_sources, event_impacts, event_job_state и др.
EVENTS_SCHEMA=harvester_news

API_PREFIX=/api/v1
# Список разрешённых origin'ов через запятую (фронт + локальная разработка).
CORS_ORIGINS=https://your-domain.example,http://127.0.0.1:6885

# Публичный путь приложения за внешним nginx.
PUBLIC_BASE_PATH=/test_news/
PUBLIC_URL=https://your-domain.example/test_news/

# Анализ событий БЕЗ платных LLM.
# semantic-rag использует локальную open-source модель embeddings и не обращается к платным API.
EVENT_ANALYSIS_MODE=semantic-rag
EVENT_CONTEXT_SOURCES_LIMIT=12
EVENT_MIN_SOURCES=3

# Semantic RAG / embeddings. Первый запуск скачает модель в docker volume semantic_models.
# На сервере с GPU поставьте SEMANTIC_DEVICE=cuda.
SEMANTIC_RAG_ENABLED=true
SEMANTIC_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SEMANTIC_DEVICE=cpu
SEMANTIC_BATCH_SIZE=32
SEMANTIC_CLUSTER_WINDOW_DAYS=5
SEMANTIC_CLUSTER_MIN_COSINE=0.66
SEMANTIC_CLUSTER_STRONG_COSINE=0.82
SEMANTIC_MIN_TOKEN_OVERLAP=0.12
SEMANTIC_MIN_TITLE_OVERLAP=0.18
SEMANTIC_MIN_CLUSTER_COHESION=0.64
SEMANTIC_EXCLUDE_DIGEST_SOURCES=true
SEMANTIC_MAX_CLUSTER_SIZE=6

# Старый быстрый fallback без embeddings, если модель не загрузилась.
EVENT_CLUSTER_WINDOW_DAYS=5
EVENT_CLUSTER_MIN_SIMILARITY=0.24

# Фоновая обработка новостей в события.
EVENT_WORKER_INTERVAL_SECONDS=300
EVENT_WORKER_BATCH_SIZE=300
EVENT_WORKER_FETCH_LIMIT=1000
EVENT_WORKER_LOOKBACK_DAYS=365
EVENT_WORKER_PROCESS_ALL=false

# ── RAGFlow: переписывание события в связную статью (заголовок + полный текст) ──
# Перед записью события worker отправляет все его источники в RAGFlow и получает
# цельную статью на русском. ВЫКЛЮЧЕНО по умолчанию — включается заданием URL+ключа.
# При ошибке/таймауте остаётся прежний extractive-заголовок/summary (fallback).
EVENT_RAGFLOW_ENABLED=false
RAGFLOW_BASE_URL=http://RAGFLOW_HOST:9380
RAGFLOW_API_KEY=your_ragflow_api_key
# Готовый ассистент (необязательно). Если пусто — создаётся/находится по имени.
RAGFLOW_CHAT_ID=
RAGFLOW_CHAT_NAME=harvester-event-writer
# Модель в RAGFlow (пусто → модель по умолчанию у тенанта).
RAGFLOW_LLM_ID=
RAGFLOW_TEMPERATURE=0.4
# Если модель reasoning-типа (Qwen3/QwQ и т.п.) — лимит токенов тратится на <think>,
# поэтому нужен большой запас, иначе сам текст ответа окажется пустым (content="").
# RAGFlow берёт max_tokens из настроек ассистента: при изменении ПЕРЕСОЗДАЙТЕ ассистента
# (удалить чат harvester-event-writer в RAGFlow или сменить RAGFLOW_CHAT_NAME).
RAGFLOW_MAX_TOKENS=8000
RAGFLOW_TIMEOUT_SECONDS=360
RAGFLOW_MAX_ATTEMPTS=3
# Минимум уникальных источников, чтобы тратить LLM (0 → берётся EVENT_MIN_SOURCES).
RAGFLOW_MIN_SOURCES=0
RAGFLOW_MAX_SOURCES=12
RAGFLOW_MAX_SOURCE_CHARS=1500

# Для первичной полной пересборки за весь доступный год:
# docker-compose run --rm events-worker python -m app.workers.events_worker --reset --once --drain
#
# Переписать существующие активные события в статьи через RAGFlow (после настройки RAGFLOW_*):
# docker compose exec events-worker python -m app.workers.events_worker --rewrite-articles
#   --rewrite-all     переписать все активные события, а не только без статьи
#   --rewrite-limit N ограничить количество
